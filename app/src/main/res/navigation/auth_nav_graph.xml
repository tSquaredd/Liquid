<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auth_nav_graph"
    app:startDestination="@id/splashScreenFragment">

    <fragment
        android:id="@+id/splashScreenFragment"
        android:name="com.tsquaredapplications.liquid.splash.SplashScreenFragment"
        android:label="fragment_splash_screen"
        tools:layout="@layout/fragment_splash_screen">
        <action
            android:id="@+id/toLoginActivity"
            app:destination="@id/loginActivity"
            app:launchSingleTop="true" />
        <action
            android:id="@+id/toMainActivity"
            app:destination="@id/mainActivity"
            app:launchSingleTop="true" />
    </fragment>
    <activity
        android:id="@+id/loginActivity"
        android:name="com.tsquaredapplications.liquid.login.LoginActivity"
        android:label="LoginActivity">
        <argument
            android:name="abandonedSignUp"
            android:defaultValue="false"
            app:argType="boolean" />
    </activity>
    <activity
        android:id="@+id/mainActivity"
        android:name="com.tsquaredapplications.liquid.MainActivity"
        android:label="activity_main"
        tools:layout="@layout/activity_main">
        <argument
            android:name="userInformation"
            app:argType="com.tsquaredapplications.liquid.common.database.users.UserInformation" />
    </activity>
</navigation>